# Backend API
VITE_BACKEND_URL=http://localhost:5000

# Firebase Web SDK
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Authentication
VITE_EMAIL_VERIFY_CONTINUE_URL=http://localhost:5173/login
VITE_PASSWORD_RESET_URL=http://localhost:5173/reset-password

# Optional (only if using Firebase Dynamic Links)
VITE_FIREBASE_DYNAMIC_LINK_DOMAIN=your.page.link

# Payments
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key